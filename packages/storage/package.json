{
  "name": "@gatrix/storage",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Pluggable file storage abstraction for Gatrix - supports local, S3-compatible, Tencent COS, Aliyun OSS, Azure Blob, Google Cloud Storage",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0",
    "@azure/storage-blob": "^12.27.0",
    "@google-cloud/storage": "^7.16.0",
    "ali-oss": "^6.22.0",
    "cos-nodejs-sdk-v5": "^2.14.9"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/node": "^20.10.4",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}
