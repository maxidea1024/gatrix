{
    "name": "@gatrix/gatrix-stale-flag-cleaner",
    "version": "1.0.0",
    "description": "CLI tool to fetch stale Gatrix feature flags and automatically remove them via AI agent with PR creation",
    "main": "dist/cli.js",
    "bin": {
        "gatrix-stale-flag-cleaner": "dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "ts-node src/cli.ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "start": "node dist/cli.js"
    },
    "keywords": [
        "feature-flags",
        "stale-flags",
        "flag-cleanup",
        "ai-agent",
        "gatrix",
        "cli"
    ],
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.2.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.0.0"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "chalk": "^4.1.2",
        "commander": "^12.0.0",
        "p-limit": "^3.1.0",
        "simple-git": "^3.22.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}