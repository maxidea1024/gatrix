<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Error</title>
  <style>
    body {
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: #0f0f23;
      color: #e2e8f0;
      font-family: system-ui, -apple-system, sans-serif;
    }
    .msg {
      text-align: center;
      padding: 2rem;
    }
    .msg h1 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
      color: #f87171;
    }
  </style>
</head>
<body>
  <div class="msg">
    <h1>{{message}}</h1>
  </div>
</body>
</html>
