{
  "name": "@gatrix/argus",
  "version": "1.0.0",
  "description": "Gatrix Argus - Error Monitoring & Performance Observability Service",
  "main": "dist/api.js",
  "scripts": {
    "dev:api": "yarn migrate:safe && ts-node-dev --poll --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist --ignore-watch logs src/api.ts",
    "dev:api:no-migrate": "ts-node-dev --poll --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist --ignore-watch logs src/api.ts",
    "dev:worker": "ts-node-dev --poll --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist --ignore-watch logs src/worker.ts",
    "build": "tsc",
    "start:api": "yarn migrate:safe && node dist/api.js",
    "start:api:no-migrate": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "migrate:clickhouse": "node scripts/migrate-clickhouse.js",
    "migrate:mysql": "node scripts/migrate-mysql.js",
    "migrate:safe": "(node scripts/migrate-clickhouse.js && node scripts/migrate-mysql.js) || echo 'Migration failed but continuing...'",
    "clean": "rimraf dist"
  },
  "keywords": [
    "error-monitoring",
    "observability",
    "performance",
    "clickhouse",
    "fastify"
  ],
  "author": "Gatrix Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@clickhouse/client": "^1.0.0",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@gatrix/gatrix-node-server-sdk": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.16.1",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.0",
    "groupmq": "^1.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "maxmind": "^4.3.11",
    "mysql2": "^3.15.0",
    "prom-client": "^15.1.3",
    "source-map": "^0.7.4",
    "ua-parser-js": "^1.0.37",
    "ulid": "^2.3.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-loki": "^6.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=8.0.0"
  }
}
