{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Edge": {
    "Port": 3400,
    "InternalPort": 3410,
    "GatrixUrl": "http://localhost:5000",
    "ApiToken": "gatrix-edge-internal-bypass-token",
    "ApplicationName": "edge-server",
    "Service": "edge",
    "Group": "gatrix",
    "Environment": "production",
    "Environments": [ "*" ],
    "Redis": {
      "Host": "localhost",
      "Port": 6379,
      "Db": 0
    },
    "Cache": {
      "PollingIntervalMs": 30000,
      "SyncMethod": "event"
    }
  }
}
