# ============================================
# Gatrix AWS ECS Deployment Configuration
# ============================================
# Copy this file to .env and update values for your environment.
#   cp .env.example .env
#
# [REQUIRED] items must be configured before deployment.
# [OPTIONAL] items have sensible defaults.

# ==============================================
# AWS Configuration [REQUIRED]
# ==============================================
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
# CloudFormation stack name prefix (stacks will be named: {prefix}-vpc, {prefix}-ecs, etc.)
CFN_STACK_PREFIX=gatrix

# ==============================================
# Container Registry (ECR) [REQUIRED]
# ==============================================
# ECR registry URL is auto-derived: {AWS_ACCOUNT_ID}.dkr.ecr.{AWS_REGION}.amazonaws.com
# ECR repository names (auto-created by build-and-push script if missing)
ECR_REPO_PREFIX=gatrix

# ==============================================
# Deployment Version [REQUIRED]
# ==============================================
# Image tag to deploy (e.g. 1.0.0, latest)
GATRIX_VERSION=latest

# ==============================================
# Cloud Database (MySQL) [REQUIRED]
# ==============================================
# Enter your Cloud MySQL (RDS) connection details.
DB_HOST=your-rds-mysql-host.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=gatrix
DB_USER=gatrix_user
DB_PASSWORD=your-secure-db-password

# ==============================================
# Cloud Redis (ElastiCache) [REQUIRED]
# ==============================================
# Enter your ElastiCache Redis connection details.
# IMPORTANT: Game servers also need access to this Redis instance
# for Pub/Sub communication (feature flags, config sync, etc.).
# Ensure the Redis security group allows connections from both
# Gatrix ECS tasks AND game server IPs.
REDIS_HOST=your-elasticache-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ==============================================
# Security Secrets [REQUIRED - must change in production]
# ==============================================
# Use ./generate-secrets.ps1 --env to generate secure random values.
# These will be stored in AWS Secrets Manager by setup-secrets script.
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
SESSION_SECRET=change-this-to-yet-another-secure-random-string

# ==============================================
# OAuth Configuration [OPTIONAL]
# ==============================================
# Google OAuth (leave empty if not used)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (leave empty if not used)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==============================================
# Grafana Monitoring [OPTIONAL]
# ==============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# ==============================================
# Application Settings [OPTIONAL]
# ==============================================
# Default language: ko (Korean), en (English), zh (Chinese)
DEFAULT_LANGUAGE=zh
VITE_APP_NAME=Gatrix
VITE_DEFAULT_LANGUAGE=zh

# ==============================================
# Admin User Seed [OPTIONAL]
# ==============================================
# Auto-created on first startup. Change password after first login!
ADMIN_EMAIL=admin@gatrix.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# ==============================================
# Service Scaling (desired task count) [OPTIONAL]
# ==============================================
BACKEND_REPLICAS=2
FRONTEND_REPLICAS=2
EDGE_REPLICAS=2

# ==============================================
# ECS Task Resources [OPTIONAL]
# ==============================================
# Fargate CPU (256, 512, 1024, 2048, 4096) and Memory (in MiB)
BACKEND_CPU=512
BACKEND_MEMORY=1024
FRONTEND_CPU=256
FRONTEND_MEMORY=512
EDGE_CPU=256
EDGE_MEMORY=512

# ==============================================
# Edge Server Configuration [OPTIONAL]
# ==============================================
# Internal service-to-service auth tokens (hardcoded convention, do NOT regenerate)
EDGE_API_TOKEN=gatrix-edge-internal-bypass-token
EDGE_BYPASS_TOKEN=gatrix-edge-internal-bypass-token
EDGE_LOG_LEVEL=info
EDGE_APPLICATION_NAME=edge-server
EDGE_SYNC_METHOD=polling
EDGE_CACHE_POLLING_INTERVAL_MS=60000
EDGE_ENVIRONMENTS=*
EDGE_FORCE_HTTPS=false

# Edge-specific Redis [REQUIRED]
# Set these to the same values as Cloud Redis above, or override
# to use a separate Redis (ElastiCache) instance for Edge.
EDGE_REDIS_HOST=your-elasticache-redis-host.cache.amazonaws.com
EDGE_REDIS_PORT=6379
EDGE_REDIS_PASSWORD=your-redis-password
EDGE_REDIS_DB=0

# ==============================================
# Monitoring [OPTIONAL]
# ==============================================
PROM_RETENTION_TIME=14d

# ==============================================
# S3 + CloudFront (Image Uploads) [OPTIONAL]
# ==============================================
# S3 bucket name (auto-generated if empty: {prefix}-uploads-{account-id})
S3_UPLOADS_BUCKET=
# CloudFront domain is auto-discovered after deployment.
# Override here if using custom domain.
CDN_BASE_URL=

# ==============================================
# Database Provisioning [OPTIONAL]
# ==============================================
# Used by cfn/09-database.yml to create RDS + ElastiCache.
# After deployment, the actual endpoints are output by CloudFormation.
# Update DB_HOST and REDIS_HOST above with the actual values.
DB_INSTANCE_CLASS=db.t4g.micro
DB_ALLOCATED_STORAGE=20
CACHE_NODE_TYPE=cache.t4g.micro

# ==============================================
# GitHub Actions CD Configuration [OPTIONAL]
# ==============================================
# These are used by the cd-ecs.yml workflow.
# Set them as GitHub repository secrets, NOT in this file.
# AWS_ACCESS_KEY_ID=    (GitHub Secret)
# AWS_SECRET_ACCESS_KEY=(GitHub Secret)
# ECS_CLUSTER_NAME=     (GitHub Secret)
# ECS_BACKEND_SERVICE=  (GitHub Secret)
# ECS_FRONTEND_SERVICE= (GitHub Secret)
# ECS_EDGE_SERVICE=     (GitHub Secret)
