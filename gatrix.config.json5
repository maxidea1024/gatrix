{
  // ============================================
  // Gatrix Configuration
  // ============================================
  //
  // This JSON5 file is the single source of truth for all Gatrix deployment settings.
  // Each service reads environment variables that are generated from this config file.
  //
  // Usage:
  //   1. Copy this file for your environment (e.g., gatrix.config.local.json5)
  //   2. Modify settings as needed
  //   3. Run: node scripts/generate-env.js [--config path/to/config.json5]
  //   4. This generates .env files consumed by docker-compose / docker stack
  //
  // Notes:
  //   - Empty string values ("") for secrets mean they will be auto-generated by the setup script
  //   - Each service has its own DB/Redis section, allowing independent infrastructure per service
  //   - Docker internal hostnames (mysql, redis, etcd) are hardcoded in docker-compose,
  //     NOT configurable here. Only external-facing settings belong in this file.

  // ============================================
  // Infrastructure
  // ============================================
  // Container-level settings for shared infrastructure services.
  // These configure the infrastructure containers themselves (e.g., root passwords, host port mappings).
  // Individual service connections to these containers are configured in each service's section below.
  infrastructure: {
    mysql: {
      // Root password for MySQL container initialization.
      // Used by MySQL container's MYSQL_ROOT_PASSWORD.
      rootPassword: "gatrix_rootpassword",

      // Port exposed on the HOST machine for external MySQL access (e.g., via MySQL Workbench).
      // Inside Docker network, services always connect via port 3306.
      hostPort: 43306,
    },

    redis: {
      // Port exposed on the HOST machine for external Redis access (e.g., via RedisInsight).
      // Inside Docker network, services always connect via port 6379.
      hostPort: 46379,
    },

    etcd: {
      // Port exposed on the HOST machine for external etcd access.
      // Inside Docker network, services connect via port 2379.
      port: 42379,
    },

    clickhouse: {
      // HTTP port exposed on the HOST for ClickHouse queries/dashboard.
      httpPort: 48123,
      // Native protocol port exposed on the HOST for ClickHouse clients.
      nativePort: 49000,
    },
  },

  // ============================================
  // Global Settings
  // ============================================
  // Settings that apply across all services.
  global: {
    // Application environment. Affects logging verbosity, rate limiting, etc.
    // Values: "development" | "production"
    nodeEnv: "development",

    // Default language for the application UI and backend responses.
    // Values: "ko" | "en" | "zh" | etc.
    defaultLanguage: "zh",

    // Root directory for all persistent Docker volume data.
    // Windows: use relative path (e.g., "./data/gatrix-storage-root")
    // Linux:   use absolute path (e.g., "/data/gatrix-storage-root")
    dataRoot: "./data/gatrix-storage-root",
  },

  // ============================================
  // Services
  // ============================================
  // Each service has its own independent configuration section.
  // Even if multiple services share the same MySQL/Redis instance,
  // they each have their own credentials here. This makes it trivial
  // to move a service to its own dedicated database later.
  services: {
    // ------------------------------------------
    // Backend API Server
    // ------------------------------------------
    // The main API server that handles all management operations,
    // feature flags, environments, organizations, etc.
    backend: {
      // Port exposed on HOST for the backend API.
      // Inside Docker, the backend always listens on port 5000.
      port: 45000,

      // Database connection for the backend service.
      // Stores: organizations, projects, environments, feature flags, users, etc.
      db: {
        name: "gatrix",        // MySQL database name
        user: "gatrix_user",   // MySQL username
        password: "gatrix_password",  // MySQL password
      },

      // Redis connection for the backend service.
      // Used for: session store, BullMQ job queues, PubSub event broadcasting, caching.
      redis: {
        password: "",  // Redis password (empty = no auth)
        db: 0,         // Redis database index (0-15)
      },

      // JWT (JSON Web Token) configuration for user authentication.
      jwt: {
        // Secret key for signing access tokens.
        // Leave empty ("") to auto-generate during setup.
        // IMPORTANT: Must be kept secret and consistent across deployments.
        secret: "",

        // Secret key for signing refresh tokens.
        // Leave empty ("") to auto-generate during setup.
        refreshSecret: "",

        // Token expiration duration.
        // Examples: "7d" (7 days), "24h" (24 hours), "30m" (30 minutes)
        expiresIn: "30d",
      },

      // Session configuration for server-side session management.
      session: {
        // Secret key for signing session cookies.
        // Leave empty ("") to auto-generate during setup.
        secret: "",

        // Maximum session age in milliseconds. Default: 86400000 (24 hours)
        maxAge: 86400000,

        // Session time-to-live in seconds for Redis store. Default: 86400 (24 hours)
        ttl: 86400,
      },

      // Default administrator account created on first startup.
      admin: {
        email: "admin@gatrix.com",
        password: "admin123",    // Change this in production!
        name: "Administrator",
      },

      // OAuth2 provider credentials for social login.
      // Leave empty ("") to disable a specific provider.
      // To obtain credentials, register your app with each provider's developer console.
      oauth: {
        google: {
          clientId: "",      // Google Cloud Console -> OAuth 2.0 Client ID
          clientSecret: "",  // Google Cloud Console -> OAuth 2.0 Client Secret
        },
        github: {
          clientId: "",      // GitHub Settings -> Developer Settings -> OAuth Apps
          clientSecret: "",
        },
        // Uncomment and configure additional providers as needed:
        // qq: { clientId: "", clientSecret: "" },
        // wechat: { clientId: "", clientSecret: "" },
        // baidu: { clientId: "", clientSecret: "" },
      },

      // SMTP configuration for sending emails (password reset, notifications, etc.).
      // If not configured, email features will be disabled.
      smtp: {
        host: "",      // SMTP server hostname (e.g., "smtp.gmail.com")
        port: 587,     // SMTP port (587 for STARTTLS, 465 for SSL)
        user: "",      // SMTP authentication username
        pass: "",      // SMTP authentication password
        from: "",      // Sender email address (e.g., "noreply@yourdomain.com")
        secure: false, // true for port 465 (SSL), false for port 587 (STARTTLS)
      },

      // SendGrid email service (alternative to SMTP).
      // If configured, takes priority over SMTP.
      // sendgrid: {
      //   apiKey: "",           // SendGrid API key
      //   from: "",             // Verified sender email
      //   verifiedSender: "",   // SendGrid verified sender identity
      // },

      // Service Discovery configuration.
      // Used to track and manage running service instances (edge, chat, event-lens).
      serviceDiscovery: {
        // Discovery backend. "etcd" for etcd-based, "redis" for Redis-based.
        mode: "etcd",

        // How often (in seconds) services send heartbeats to prove they're alive.
        heartbeatTTL: 30,

        // How long (in seconds) to keep showing inactive services in the UI
        // after they stop sending heartbeats.
        inactiveKeepTTL: 60,

        // How long (in seconds) to keep terminated service markers for audit trail.
        terminatedMarkerTTL: 300,
      },

      // Data retention settings (in days).
      // Old data beyond these limits is automatically cleaned up by scheduled jobs.
      retention: {
        featureFlagMetricsDays: 14,       // Feature flag evaluation metrics
        planningDataDays: 14,             // Planning/scheduling data
        changeRequestRejectionDays: 14,   // Rejected change request history
        serverLifecycleDays: 14,          // Server lifecycle event logs
      },

      // Logging configuration for the backend service.
      logging: {
        // Log level. Values: "error" | "warn" | "info" | "debug"
        level: "debug",

        // Directory for log files (relative to the app root).
        dir: "logs",
      },

      // Disable rate limiting entirely. Set to true for development, false for production.
      disableRateLimit: true,
    },

    // ------------------------------------------
    // Crash Database (separated for load isolation)
    // ------------------------------------------
    // The crash reporting feature generates high write volume.
    // Separating it into its own database prevents crash data
    // from impacting the performance of the main backend database.
    //
    // Tables stored here:
    //   - g_crashes: Crash group definitions
    //   - g_crash_events: Individual crash event records
    //   - g_crash_retention_settings: Per-environment retention policies
    crashDb: {
      name: "gatrix_crash",       // MySQL database name for crash data
      user: "gatrix_user",        // MySQL username (can be same as backend or dedicated)
      password: "gatrix_password",
    },

    // ------------------------------------------
    // Chat Server
    // ------------------------------------------
    // Real-time messaging server using Socket.IO.
    // Handles WebSocket connections, message broadcasting, and chat rooms.
    chatServer: {
      // Port exposed on HOST for the chat server API.
      // Inside Docker, the chat server always listens on port 5100.
      port: 45100,

      // Database connection for chat data.
      // Stores: channels, messages, user presence, read receipts, etc.
      db: {
        name: "gatrix_chat",
        user: "gatrix_user",
        password: "gatrix_password",
      },

      // Redis connection for the chat server.
      // Used for: Socket.IO adapter (cross-instance message routing), session store,
      //           presence tracking, pub/sub notifications.
      redis: {
        password: "",
        db: 1,  // Uses a different Redis DB than backend to avoid key conflicts
      },

      // Node.js cluster mode for utilizing multiple CPU cores.
      cluster: {
        enabled: true,   // Enable cluster mode for production workloads
        workers: 0,      // Number of worker processes. 0 = auto (uses all CPU cores)
        stickySession: true,  // Required for WebSocket connections across workers
      },

      // Message broadcasting optimization settings.
      broadcasting: {
        batchSize: 1000,         // Messages per batch for broadcast operations
        useMessagePack: true,    // Use MessagePack binary serialization (faster than JSON)
        compression: true,       // Enable per-message deflate compression
      },

      // WebSocket limits.
      ws: {
        maxConnections: 10000,   // Maximum concurrent WebSocket connections per instance
      },

      logging: {
        level: "info",
      },
    },

    // ------------------------------------------
    // Event Lens (Analytics Server)
    // ------------------------------------------
    // Ingests, processes, and queries analytics events.
    // Uses ClickHouse for high-volume event storage and MySQL for metadata.
    eventLens: {
      // Port exposed on HOST for the Event Lens API.
      // Inside Docker, listens on port 5200.
      port: 45200,

      // MySQL connection for Event Lens metadata.
      // NOTE: Event Lens uses MYSQL_* environment variables (not DB_*).
      // This is because it uses a separate MySQL client library.
      db: {
        name: "gatrix",
        user: "gatrix_user",
        password: "gatrix_password",
      },

      // Redis connection for Event Lens.
      // Used for: event buffering, job queues, caching.
      redis: {
        password: "",
        db: 0,
      },

      // ClickHouse connection for high-volume event storage.
      // ClickHouse host/port are hardcoded in docker-compose (clickhouse:8123).
      clickhouse: {
        database: "event_lens",  // ClickHouse database name (auto-created)
        username: "default",     // ClickHouse username
        password: "",            // ClickHouse password (empty = no auth)
      },

      // Background worker settings for batch-processing incoming events.
      worker: {
        batchSize: 1000,      // Events per batch insert into ClickHouse
        batchTimeout: 5000,   // Max wait time (ms) before flushing partial batch
        concurrency: 10,      // Number of concurrent worker threads
      },

      logging: {
        level: "info",
      },
    },

    // ------------------------------------------
    // Edge Server
    // ------------------------------------------
    // High-availability, client-facing API proxy.
    // Caches feature flags and serves them to game clients,
    // even when the backend is temporarily unavailable.
    edge: {
      // Port exposed on HOST for Edge API.
      // Inside Docker, listens on port 3400.
      port: 3400,

      // Redis connection for the Edge server.
      // Used for: PubSub cache synchronization (event mode), flag data caching.
      // Can point to a dedicated Redis instance separate from the main one.
      redis: {
        host: "redis",    // Redis hostname (use "redis" for Docker network)
        port: 6379,       // Redis port
        password: "",     // Redis password
        db: 0,            // Redis database index
      },

      // Cache synchronization strategy.
      cache: {
        // How the Edge server keeps its cache in sync with the backend.
        // "event":   Real-time updates via Redis PubSub (recommended for production)
        // "polling": Periodically fetch all data from backend API
        // "manual":  Only refresh when explicitly triggered via API
        syncMethod: "event",

        // Polling interval in milliseconds. Only used when syncMethod is "polling".
        pollingIntervalMs: 60000,
      },

      // Token that allows Edge server to access all environments on the backend.
      // This is an internal token, not exposed to clients.
      // IMPORTANT: Change this to a strong random value in production!
      bypassToken: "gatrix-edge-internal-bypass-token",

      // Application name used for service discovery registration.
      applicationName: "edge-server",

      // Whether to enforce HTTPS security headers (HSTS, etc.).
      // Set to false for HTTP-only development environments to avoid SSL errors.
      forceHttps: false,

      logging: {
        level: "info",
      },
    },

    // ------------------------------------------
    // Frontend (Nginx + Static Files)
    // ------------------------------------------
    // Serves the Gatrix admin dashboard (React SPA).
    // Nginx acts as reverse proxy to backend API.
    frontend: {
      // Port exposed on HOST for the frontend.
      port: 43000,

      // HTTPS port (if SSL is configured in Nginx).
      httpsPort: 43443,

      // Vite build-time environment variables.
      // These are baked into the frontend bundle at build time.
      vite: {
        // Backend API base URL (relative path for same-origin, proxied via Nginx).
        apiUrl: "/api/v1",

        // Application display name shown in the UI.
        appName: "Gatrix",

        // NOTE: grafanaUrl, bullBoardUrl, and edgeUrl are generated
        // by the setup script based on the host address and protocol.
      },
    },
  },

  // ============================================
  // Monitoring
  // ============================================
  // Configuration for observability stack (Grafana, Prometheus, Loki).
  monitoring: {
    grafana: {
      adminUser: "admin",
      adminPassword: "admin",   // Change in production!

      // Domain name for Grafana (used in CSRF/cookie settings).
      domain: "localhost",

      // Port exposed on HOST for Grafana dashboards.
      port: 44000,

      // CORS trusted origins for embedding Grafana dashboards.
      // Use "*" to allow all origins (convenient for development).
      // In production, specify exact origins: "https://yourdomain.com"
      trustedOrigins: "*",
      allowedOrigins: "*",
    },

    prometheus: {
      // Port exposed on HOST for Prometheus metrics UI.
      port: 49090,

      // How long to retain metrics data. Examples: "7d", "14d", "30d"
      retentionTime: "14d",
    },

    loki: {
      // Port exposed on HOST for Loki log aggregation API.
      port: 43100,
    },
  },

  // ============================================
  // Swarm Deployment
  // ============================================
  // Settings specific to Docker Swarm mode deployment.
  // These are only used when deploying via `docker stack deploy`.
  swarm: {
    // Number of replicas for each service.
    // Increase for high-availability and load distribution.
    replicas: {
      backend: 1,
      frontend: 1,
      eventLens: 1,
      eventLensWorker: 1,
      chatServer: 1,
      edge: 1,
    },

    // Port mappings for the Nginx reverse proxy in Swarm mode.
    ports: {
      http: 43000,        // HTTP entry point
      https: 443,         // HTTPS entry point (requires SSL certificates)
      portainer: 9000,    // Portainer cluster management UI
      visualizer: 8080,   // Docker Swarm visualizer
    },
  },
}
